# Database connection string
DATABASE_URL="postgresql://username:password@localhost:5432/capitalbridge?schema=public"

# Server configuration
PORT=3000
NODE_ENV=development

# Token configuration
TOKEN_EXPIRATION_HOURS=72

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Email configuration
# For Gmail: Use 'gmail' and generate an App Password from your Google account
# For custom SMTP: Use EMAIL_HOST, EMAIL_PORT, EMAIL_USER, EMAIL_PASSWORD
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@capitalbridge.com
EMAIL_FROM_NAME=Capital Bridge Nepal

# Optional: Custom SMTP settings (if not using Gmail)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587

# Better Auth configuration
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
